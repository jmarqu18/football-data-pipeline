# .env.example — Variables de entorno para el stack de desarrollo.
# Copiar a .env y completar los valores reales antes de `podman-compose up`.
# NUNCA commitear .env al repositorio.

# ── Obligatorio ───────────────────────────────────────────────────────────────

# Clave de API-Football (https://www.api-football.com)
# Requerida por los DAGs de ingesta (os.environ["API_FOOTBALL_KEY"]).
API_FOOTBALL_KEY=your_api_key_here

# ── Opcional: claves de seguridad ─────────────────────────────────────────────
# Si se omiten, compose.yml usa los valores de desarrollo hardcodeados.
# En producción, generar valores únicos y rotarlos.

# Fernet key para cifrado de conexiones y variables en Airflow.
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# Secret key del webserver de Airflow (firma de sesiones).
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
# AIRFLOW__WEBSERVER__SECRET_KEY=dev-secret-key-change-in-prod

# ── Opcional: override de config ──────────────────────────────────────────────
# PIPELINE_CONFIG_PATH=/path/to/ingestion.yaml
